# Server
PORT=3000
NODE_ENV=development

# JWT
JWT_SECRET=super_strong_secret_change_this
JWT_EXPIRES_IN=1h
BCRYPT_ROUNDS=10

# MySQL (Railway)
DB_HOST=YOUR_RAILWAY_HOST
DB_PORT=3306
DB_USER=YOUR_RAILWAY_USER
DB_PASSWORD=YOUR_RAILWAY_PASSWORD
DB_NAME=railway
DB_CONNECTION_LIMIT=10

# CORS
# Comma separated list. Use your Netlify URL + local URL.
CORS_ORIGIN=https://your-app.netlify.app,http://localhost:5500
